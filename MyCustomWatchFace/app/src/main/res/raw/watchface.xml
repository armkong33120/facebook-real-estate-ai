<?xml version="1.0" encoding="utf-8"?>
<!-- 
  Watch Face Format (WFF) - Declarative UI for Wear OS 
  Designed per the user's mockup constraints.
-->
<WatchFace width="450" height="450">
    <Scene>
        <!-- Background Layer -->
        <PartImage x="0" y="0" width="450" height="450">
            <Image resource="background_default"/>
        </PartImage>

        <!-- Dynamic Date (e.g., THU, OCT 26) -->
        <PartText x="225" y="120" width="250" height="50" pivotX="0.5" pivotY="0.5">
            <Text align="CENTER">
                <Font family="SYNC-TO-DEVICE" size="24" color="#E0E0E0"/>
                <Template>
                    <Parameter expression="[DAY_OF_WEEK_S], [MONTH_S] [DAY]"/>
                </Template>
            </Text>
        </PartText>

        <!-- Main Time (14:30) -->
        <PartText x="150" y="225" width="180" height="100" pivotX="0.5" pivotY="0.5">
            <Text align="RIGHT">
                <Font family="SYNC-TO-DEVICE" size="84" color="#FFFFFF"/>
                <Template>
                    <Parameter expression="[HOUR_0_23]:[MINUTE]"/>
                </Template>
            </Text>
        </PartText>

        <!-- "TH" Text Badge (Neon Green) -->
        <PartText x="300" y="225" width="80" height="80" pivotX="0.5" pivotY="0.5">
            <Text align="LEFT">
                <Font family="SYNC-TO-DEVICE" size="42" color="#BFFF00" weight="BOLD"/>
                <Template>
                    <Parameter expression="TH"/>
                </Template>
            </Text>
        </PartText>

        <!-- Sub Time (02:30 PM) -->
        <PartText x="225" y="310" width="200" height="50" pivotX="0.5" pivotY="0.5">
            <Text align="CENTER">
                <Font family="SYNC-TO-DEVICE" size="36" color="#FFFFFF"/>
                <Template>
                    <Parameter expression="[HOUR_1_12_Z]:[MINUTE] [AMPM]"/>
                </Template>
            </Text>
        </PartText>

        <!-- Battery Percentage at Bottom -->
        <PartText x="225" y="400" width="120" height="30" pivotX="0.5" pivotY="0.5">
            <Text align="CENTER">
                <Font family="SYNC-TO-DEVICE" size="22" color="#BFFF00"/>
                <Template>
                    <Parameter expression="[BATTERY_PERCENT]%"/>
                </Template>
            </Text>
        </PartText>
    </Scene>
</WatchFace>
